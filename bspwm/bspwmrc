#!/bin/sh

#################################################
#                 BSPWM - Clean Laptop          #
#                  by Yusufbek                  #
#################################################

### –ú–ĺ–Ĺ–ł—ā–ĺ—Ä—č –ł —Ä–į–Ī–ĺ—á–ł–Ķ —Ā—ā–ĺ–Ľ—č
bspc monitor -d 1 2 3 4 5 6 7 8 9

#################################################
# –ě—Ā–Ĺ–ĺ–≤–Ĺ—č–Ķ –Ĺ–į—Ā—ā—Ä–ĺ–Ļ–ļ–ł
#################################################

bspc config border_width         2
bspc config window_gap           12
bspc config split_ratio          0.55
bspc config borderless_monocle   true
bspc config gapless_monocle      true
bspc config single_monocle       false

# –§–ĺ–ļ—É—Ā —Ā–Ľ–Ķ–ī—É–Ķ—ā –∑–į –ļ—É—Ä—Ā–ĺ—Ä–ĺ–ľ (—É–ī–ĺ–Ī–Ĺ–ĺ –Ĺ–į –Ĺ–ĺ—É—ā–Ī—É–ļ–Ķ)
bspc config focus_follows_pointer true

# –¶–≤–Ķ—ā–į (–Ņ–ĺ–ī —ā–≤–ĺ–Ļ —ā—Ď–ľ–Ĺ—č–Ļ —Ā—ā–ł–Ľ—Ć)
bspc config focused_border_color   "#89b4fa"
bspc config normal_border_color    "#313244"
bspc config active_border_color    "#585b70"
bspc config presel_feedback_color  "#f38ba8"

#################################################
#–ź–≤—ā–ĺ–∑–į–Ņ—É—Ā–ļ
#################################################

#Picom (–ļ–ĺ–ľ–Ņ–ĺ–∑–ł—ā–Ĺ—č–Ļ –ľ–Ķ–Ĺ–Ķ–ī–∂–Ķ—Ä –ī–Ľ—Ź —ā–Ķ–Ĺ–Ķ–Ļ –ł –Ņ—Ä–ĺ–∑—Ä–į—á–Ĺ–ĺ—Ā—ā–ł)
picom --config ~/.config/picom/picom.conf &

# –ö—É—Ä—Ā–ĺ—Ä
xsetroot -cursor_name left_ptr &

# –ü—Ä–ĺ–≥—Ä–į–ľ–ľ–į –ī–Ľ—Ź —Ā–ļ—Ä–ł–Ĺ—ą–ĺ—ā–į Flameshot 
pgrep -x flameshot > /dev/null || flameshot &

# –ď–ĺ—Ä—Ź—á–ł–Ķ –ļ–Ľ–į–≤–ł—ą–ł
pgrep -x sxhkd > /dev/null || sxhkd &

# –ě–Ī–ĺ–ł
nitrogen --restore &

# PolicyKit
pgrep -x lxpolkit > /dev/null || lxpolkit &

# –£–≤–Ķ–ī–ĺ–ľ–Ľ–Ķ–Ĺ–ł—Ź
pgrep -x dunst > /dev/null || dunst &

# Polybar
~/.config/polybar/launch.sh &

# –†–į—Ā–ļ–Ľ–į–ī–ļ–į –ļ–Ľ–į–≤–ł–į—ā—É—Ä—č (US + RU)
setxkbmap -layout us,ru -option grp:win_space_toggle &

#################################################
# –ü—Ä–į–≤–ł–Ľ–į –ĺ–ļ–ĺ–Ĺ
#################################################

# –ü–Ľ–į–≤–į—é—Č–ł–Ķ –ĺ–ļ–Ĺ–į
bspc rule -a Pavucontrol state=floating
bspc rule -a Blueman-manager state=floating
bspc rule -a feh state=floating
bspc rule -a mpv state=floating

# Firefox –Ĺ–į 2 —Ä–į–Ī–ĺ—á–ł–Ļ —Ā—ā–ĺ–Ľ
bspc rule -a google-chrome-stable desktop='^2'

# Telegram –Ĺ–į 8
bspc rule -a TelegramDesktop desktop='^9'

#################################################
# –≠–Ĺ–Ķ—Ä–≥–ĺ—Ā–Ī–Ķ—Ä–Ķ–∂–Ķ–Ĺ–ł–Ķ (–Ĺ–ĺ—É—ā–Ī—É–ļ)
#################################################

# –ě—ā–ļ–Ľ—é—á–į–Ķ–ľ –į–≤—ā–ĺ-–Ī–Ľ–ĺ–ļ–ł—Ä–ĺ–≤–ļ—É —ć–ļ—Ä–į–Ĺ–į
xset -dpms
xset s off

